# Optional. If unset, the site URL is derived automatically from Vercel's
# VERCEL_PROJECT_PRODUCTION_URL at build time, so canonical URLs / OG tags /
# sitemaps update on their own when a custom domain is attached.
NEXT_PUBLIC_SITE_URL=

# Optional. The content= value Google Search Console gives you for the
# "HTML tag" verification method.
GOOGLE_SITE_VERIFICATION=
